NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USER=neo4j
# Aura download file may use NEO4J_USERNAME / NEO4J_DATABASE instead
NEO4J_PASSWORD=your_aura_password

ANTHROPIC_API_KEY=your_key

# GitHub — required for profile ingest (avoids 60 req/hr anonymous rate limit)
# Create at: https://github.com/settings/tokens (public repo read is enough)
GITHUB_TOKEN=ghp_xxxxxxxx

# RocketRide Cloud (Person D) — see rocketride/README.md
# ROCKETRIDE_URI=https://cloud.rocketride.ai
# ROCKETRIDE_APIKEY=your_cloud_api_key
# ROCKETRIDE_PIPELINE=../rocketride/hivemind-decision-extract.pipe
# ROCKETRIDE_ANTHROPIC_KEY=your_anthropic_key
# ROCKETRIDE_HTTP_URL=https://optional-direct-webhook-url

# Butterbase — from dashboard.butterbase.ai → your app → API Keys
BUTTERBASE_APP_ID=app_xxxxxxxx
BUTTERBASE_API_URL=https://api.butterbase.ai
BUTTERBASE_API_KEY=bb_key_xxxxxxxx
BUTTERBASE_ANON_KEY=bb_anon_xxxxxxxx
# From npm run setup:billing
BUTTERBASE_TEAM_PRODUCT_ID=uuid-from-setup-billing
