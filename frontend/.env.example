VITE_BUTTERBASE_APP_ID=app_xxxxxxxx
VITE_BUTTERBASE_API_URL=https://api.butterbase.ai
# Optional — only needed for locked-down apps; public apps can read app_config without it
VITE_BUTTERBASE_ANON_KEY=bb_anon_xxxxxxxx
# NOT needed — backend URL is loaded at runtime from Butterbase app_config (host: npm run publish:api-url)
# VITE_API_URL=http://localhost:3001
# From npm run setup:billing
VITE_BUTTERBASE_TEAM_PRODUCT_ID=uuid-from-setup-billing
